{
  "@context": {
    "@vocab": "https://docs.mangopay.com/api-reference/",
    "schema": "https://schema.org/",
    "mangopay": "https://docs.mangopay.com/api-reference/",
    "User": "mangopay:users",
    "NaturalUser": "mangopay:users/natural",
    "LegalUser": "mangopay:users/legal",
    "Wallet": "mangopay:wallets",
    "PayIn": "mangopay:pay-ins",
    "PayOut": "mangopay:pay-outs",
    "Transfer": "mangopay:transfers",
    "Refund": "mangopay:refunds",
    "Dispute": "mangopay:disputes",
    "KYCDocument": "mangopay:kyc/documents",
    "UBODeclaration": "mangopay:ubo-declarations",
    "BankAccount": "mangopay:users/bank-accounts",
    "Card": "mangopay:cards",
    "CardRegistration": "mangopay:card-registrations",
    "Mandate": "mangopay:mandates",
    "Transaction": "mangopay:transactions",
    "Hook": "mangopay:hooks",
    "Report": "mangopay:reports",
    "Conversion": "mangopay:conversions",
    "Recipient": "mangopay:recipients",
    "IDVSession": "mangopay:idv-sessions",
    "Id": "schema:identifier",
    "Tag": "schema:name",
    "CreationDate": "schema:dateCreated",
    "Status": "schema:status",
    "Currency": "schema:currency",
    "Amount": "schema:amount",
    "UserId": {
      "@type": "@id",
      "@id": "schema:agent"
    },
    "WalletId": {
      "@type": "@id",
      "@id": "mangopay:wallet"
    },
    "DebitedFunds": "schema:price",
    "CreditedFunds": "schema:price",
    "Fees": "mangopay:fees",
    "ResultCode": "mangopay:resultCode",
    "ResultMessage": "mangopay:resultMessage",
    "FirstName": "schema:givenName",
    "LastName": "schema:familyName",
    "Email": "schema:email",
    "Birthday": "schema:birthDate",
    "Nationality": "schema:nationality",
    "CountryOfResidence": "schema:addressCountry",
    "CompanyNumber": "schema:taxID",
    "Name": "schema:name",
    "Description": "schema:description",
    "Balance": "mangopay:balance",
    "BlockedBalance": "mangopay:blockedBalance",
    "PaymentType": "mangopay:paymentType",
    "ExecutionType": "mangopay:executionType",
    "CardType": "mangopay:cardType",
    "Alias": "mangopay:alias",
    "ExpirationDate": "schema:expires",
    "Type": "mangopay:documentType",
    "PersonType": "mangopay:personType",
    "KYCLevel": "mangopay:kycLevel",
    "UserCategory": "mangopay:userCategory",
    "DisputeType": "mangopay:disputeType",
    "DisputeReason": "mangopay:disputeReason",
    "ContestDeadlineDate": "mangopay:contestDeadlineDate",
    "Quote": "mangopay:quote",
    "ConversionRate": "mangopay:conversionRate",
    "baseURL": "mangopay:baseURL",
    "version": "schema:version",
    "environment": "mangopay:environment"
  },
  "@type": "schema:WebAPI",
  "schema:name": "Mangopay REST API",
  "schema:description": "European payment infrastructure platform providing REST APIs for marketplace payments, digital wallet management, user KYC/KYB verification, fund transfers, currency conversion, and payment card processing.",
  "schema:url": "https://docs.mangopay.com",
  "schema:provider": {
    "@type": "schema:Organization",
    "schema:name": "Mangopay",
    "schema:url": "https://mangopay.com"
  },
  "schema:documentation": "https://docs.mangopay.com/api-reference",
  "schema:version": "2.01",
  "schema:termsOfService": "https://mangopay.com/terms-and-conditions"
}